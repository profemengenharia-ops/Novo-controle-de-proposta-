rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Proposal Rules ---
    function isValidProposal(data) {
      return data.keys().hasAll(['clientName', 'proposalNumber', 'status', 'createdBy']) &&
             data.clientName is string && data.clientName.size() <= 200 &&
             data.proposalNumber is string && data.proposalNumber.size() <= 50 &&
             data.status in ['rascunho', 'enviada', 'em_negociacao', 'ganha', 'perdida', 'expirada'] &&
             data.createdBy == request.auth.uid;
    }

    match /proposals/{proposalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(proposalId) && 
                      isValidProposal(incoming());
                      // Removed strict request.time check as app uses ISO strings for now

      allow update: if isSignedIn() &&
                      isValidId(proposalId) &&
                      isValidProposal(incoming()) &&
                      incoming().createdBy == existing().createdBy && (
                        // Standard updates
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'clientName', 'scopeTitle', 'status', 'technicalScope', 
                          'commercialProposal', 'updatedAt', 'validityDays', 
                          'deadline', 'lossReason', 'interactions', 'revisions', 'revision'
                        ])
                      );

      allow delete: if isSignedIn() && isOwner(existing().createdBy);
    }

    // --- Product Rules ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string &&
             data.price is number && data.price >= 0;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isSignedIn();
    }

    // --- Norm Rules ---
    match /norms/{normId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Restricted in production, but open for now
    }
  }
}
