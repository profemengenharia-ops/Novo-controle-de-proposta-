# Supabase
# Create a project at https://supabase.com and paste the values from
# Project Settings > API.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google AI (Gemini)
# Keep the API key as a Supabase Edge Function secret, never as a VITE_* browser variable:
# supabase secrets set GEMINI_API_KEY=your_gemini_api_key
# Optional Edge Function secret:
# supabase secrets set GEMINI_MODEL=gemini-2.5-flash
# Optional browser-side model override passed to the Edge Function:
VITE_GEMINI_MODEL=gemini-2.5-flash

# Vercel deployment notes
# 1. Add all VITE_* variables above in Vercel Project Settings > Environment Variables.
# 2. In Supabase Authentication > URL Configuration, add your Vercel domain
#    to Redirect URLs, for example https://your-app.vercel.app.
# 3. Deploy Edge Functions separately with:
#    npx supabase functions deploy ai-generate
#    npx supabase functions deploy calculate-pricing
#    npx supabase functions deploy generate-pdf-proposal
