# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com and paste the values from
# Project Settings → API.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key
# Optional: override the model (defaults to gemini-2.5-flash-preview-04-17)
VITE_GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ─── Vercel deployment notes ─────────────────────────────────────────────────
# 1. Add all VITE_* variables above in Vercel → Project Settings → Environment Variables.
# 2. In Supabase → Authentication → URL Configuration, add your Vercel domain
#    to "Redirect URLs" (e.g. https://your-app.vercel.app).
# 3. If you use Supabase Edge Functions, deploy them separately with:
#    npx supabase functions deploy <function-name>
